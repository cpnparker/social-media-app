# local env files — CATCH-ALL. Named rules kept missing new variants
# (.env.check.engineai was untracked but unignored, one `git add -A` from
# publishing production secrets). Anything starting with .env is ignored;
# add an explicit negation if a committed example file is ever needed.
.env*

# vercel
.vercel

# local uploads
/public/uploads

# typescript
*.tsbuildinfo
next-env.d.ts
